TEAMCENTER_USERNAME=your.username
TEAMCENTER_PASSWORD=change-me
TEAMCENTER_USE_CASE=part_creation
TEAMCENTER_LOCATOR_PROFILE=default/teamcenter_generic
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_MCP_ENABLED=true
